<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    ###############################
    # Force HTTPS and www
    ###############################
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]
    
    # /Redirect old pages /
    RewriteRule ^products\.php$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^partners\.php$ https://www.goldenharbour.com/our-agencies [R=301,L]
    RewriteRule ^hydraulic_tube_fittings\.php$ https://www.goldenharbour.com/product/hydrualic-instrumentation [R=301,L]
    RewriteRule ^certification\.php$ https://www.goldenharbour.com/certifications [R=301,L]
    RewriteRule ^logistics\.php$ https://www.goldenharbour.com/about [R=301,L]
    RewriteRule ^classicfilters\.php$ https://www.goldenharbour.com/product/hydrualic-instrumentation/classic-filters [R=301,L]
    RewriteRule ^packing_fibre_glass\.php$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^heat_exchange\.php$ https://www.goldenharbour.com/product/heat-exchanger-condensors-pipes-tubes-fittings [R=301,L]
    RewriteRule ^sheets_shims\.php$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^pipes\.php$ https://www.goldenharbour.com/product/heat-exchanger-condensors-pipes-tubes-fittings/stainless-steel [R=301,L]
    RewriteRule ^lmcmaking\.php$ https://www.goldenharbour.com/product/hydrualic-instrumentation/lmc-makina [R=301,L]
    RewriteRule ^all_products\.php$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^about_us\.php$ https://www.goldenharbour.com/about [R=301,L]
    RewriteRule ^contact_us\.php$ https://www.goldenharbour.com/contact [R=301,L]
    RewriteRule ^perforated_sheets_wire_mesh\.php$ https://www.goldenharbour.com/product/ferrous-metal-alloys/carbon-steel/perforated-sheets/detail [R=301,L]
    RewriteRule ^marine_valves\.php$ https://www.goldenharbour.com/product/non-ferrous-metal-alloys/brass/valves/detail [R=301,L]
    RewriteRule ^others\.php$ https://www.goldenharbour.com/product/other-products [R=301,L]
    RewriteRule ^bronze_round_hollowbushings\.php$ https://www.goldenharbour.com/product/non-ferrous-metal-alloys/bronze/round-bar/detail [R=301,L]
    RewriteRule ^gaskets_and_packings\.php$ https://www.goldenharbour.com/product/other-products [R=301,L]
    RewriteRule ^ptfe_teflon_nylon_neoprene\.php$ https://www.goldenharbour.com/product/non-metallic/teflon-ptfe [R=301,L]
    RewriteRule ^lmcmaking\.php/.*$ https://www.goldenharbour.com/product/hydrualic-instrumentation/lmc-makina [R=301,L]
    RewriteRule ^all_products\.php/.*$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^FlipBook1/flipbook\.html$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^FlipBook1/files/basic-html/page29\.html$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^chairman-message\.php$ https://www.goldenharbour.com/about [R=301,L]
    RewriteRule ^FlipBook1/files/basic-html/page27\.html$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^FlipBook1/files/basic-html/page33\.html$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^FlipBook1/files/basic-html/page36\.html$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^marine_valves\.php/.*$ https://www.goldenharbour.com/product/non-ferrous-metal-alloys/brass/valves/detail [R=301,L]
    RewriteRule ^Uni-Coupling\.php$ https://www.goldenharbour.com/product/other-products/uni-couplings/uni-couplings/detail [R=301,L]
    RewriteRule ^FlipBook1/files/basic-html/index\.html$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^virtual-tour\.php$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^files/hoke-catalogue\.pdf$ https://www.goldenharbour.com/product/hydrualic-instrumentation/hoke [R=301,L]
    RewriteRule ^sheets_shims\.php/news\.php$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^perforated_sheets_wire_mesh\.php/news\.php$ https://www.goldenharbour.com/product/ferrous-metal-alloys/carbon-steel/perforated-sheets/detail [R=301,L]
    RewriteRule ^images/GH\ Catalogue\.pdf$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^FlipBook/files/basic-html/page25\.html$ https://www.goldenharbour.com/ [R=301,L]
    RewriteRule ^files/HOKE-ABV-SERIES-2&3WAY-VALVES\.pdf$ https://www.goldenharbour.com/product/hydrualic-instrumentation/hoke/ball-valves/abv-series-ball-valves/detail [R=301,L]
    RewriteRule ^cdn-cgi/l/email-protection$ https://www.goldenharbour.com/ [R=301,L]

    ###############################
    # Handle Authorization Header
    ###############################
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    ###############################
    # Redirect Trailing Slashes If Not A Folder
    ###############################
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    ###############################
    # Send Requests To Front Controller
    ###############################
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
    
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
